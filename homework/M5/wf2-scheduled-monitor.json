          "id": "bCTV2MSaGpiOApcA",
          "name": "Bearer Auth account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://accurately-month-insured-rows.trycloudflare.com/mcp",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "httpBearerAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Accept",
              "value": "application/json, text/event-stream"
            },
            {
              "name": "mcp-session-id",
              "value": "={{ $('Init MCP').item.json.headers['mcp-session-id'] }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"get_feature_info\",\"arguments\":{\"feature_id\":\"{{ $('Read & Analyze Logs').item.json.feature_id }}\"}}}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        544,
        -80
      ],
      "id": "09376461-16b5-4871-9cd1-2f1e73522d7a",
      "name": "Get Feature Status",
      "credentials": {
        "httpBearerAuth": {
          "id": "bCTV2MSaGpiOApcA",
          "name": "Bearer Auth account"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $('Get Feature Status').item.json.data; \n\n// Извлечь JSON из SSE строки\nconst jsonStr = raw.split('\\n').find(line => line.startsWith('data: '))?.slice(6);\n\nif (!jsonStr) {\n  throw new Error('No data line found in SSE response');\n}\n\nconst mcpResponse = JSON.parse(jsonStr);\nconst featureData = JSON.parse(mcpResponse.result.content[0].text);                             \nreturn {\n  json: {\n    feature_id: $('Read & Analyze Logs').item.json.feature_id,\n    error_rate: $('Read & Analyze Logs').item.json.error_rate,\n    total: $('Read & Analyze Logs').item.json.total,\n    current_status: featureData.status,\n    traffic_percentage: featureData.traffic_percentage,\n    name: featureData.name\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        -80
      ],
      "id": "76e92f0c-a69a-4278-bc2b-e844d94c80dd",
      "name": "Merge Responses"
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 3
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.error_rate > 0.05 && $json.current_status !== 'Disabled' }}",
                    "rightValue": "",
                    "operator": {
                      "type": "boolean",
                      "operation": "true",
                      "singleValue": true
                    },
                    "id": "60675c54-9f0b-41c1-8386-1a6e607ec1d2"
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "deactivate"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict",
                  "version": 3
                },
                "conditions": [
                  {
                    "id": "6adb7d35-dbac-4de3-add0-4a2b9aff15e8",
                    "leftValue": "={{ $json.error_rate < 0.01 && $json.current_status === 'Disabled' }}",
                    "rightValue": "",
                    "operator": {
                      "type": "boolean",
                      "operation": "true",
                      "singleValue": true
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "reenable"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
