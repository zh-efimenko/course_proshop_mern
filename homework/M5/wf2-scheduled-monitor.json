      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst data = items.map(item => item.json);\n\nconst now = Date.now();\nconst window_ms = 60 * 1000;\nconst recent = data.filter(e => (now - new Date(e.timestamp).getTime()) < window_ms);\n\nconst total = recent.length;\nconst errorItems = recent.filter(e => e.status === 'error');\nconst errors = errorItems.length;\nconst error_rate = total > 0 ? errors / total : 0;\n\n// Берём feature_id из первой записи с ошибкой, или из первой записи вообще\nconst feature_id = errorItems[0]?.feature_id ?? recent[0]?.feature_id ?? 'unknown';\n\nreturn [{ json: { feature_id, error_rate, total, errors } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        96,
        -80
      ],
      "id": "9c1b49a9-e24f-4284-a2b8-d704a9126dda",
      "name": "Read & Analyze Logs"
    },
